{
    "name": "projecteuler",
    "displayName": "Project Euler",
    "publisher": "slfotg",
    "description": "Allow viewing Project Euler problems from your editor",
    "icon": "images/euler.png",
    "version": "0.0.9",
    "repository": {
        "type": "git",
        "url": "https://github.com/slfotg/projecteuler"
    },
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "properties": {
                "projecteuler.enableCodeLens": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable editor links for Euler Problems (matches on 'pe###', 'problem=###', or 'problem = ###')"
                }
            }
        },
        "commands": [
            {
                "command": "projecteuler.searchProblem",
                "title": "Euler: Search Problem",
                "icon": "$(search)"
            },
            {
                "command": "projecteuler.pickProblem",
                "title": "Search Problem",
                "icon": "$(search)"
            },
            {
                "command": "projecteuler.showProblem",
                "title": "Show Problem",
                "icon": "$(go-to-file)"
            },
            {
                "command": "projecteuler.refreshMetadata",
                "title": "Refresh Problem Data",
                "icon": "$(refresh)"
            },
            {
                "command": "projecteuler.clearMetadata",
                "title": "Clear Problem Data"
            },
            {
                "command": "projecteuler.newSubFolder",
                "title": "New Folder",
                "icon": "$(new-folder)"
            },
            {
                "command": "projecteuler.newFolder",
                "title": "New Folder",
                "icon": "$(new-folder)"
            },
            {
                "command": "projecteuler.addToFavorites",
                "title": "Add to Favorites",
                "icon": "$(heart)"
            },
            {
                "command": "projecteuler.deleteFromFavorites",
                "title": "Remove from Favorites",
                "icon": "$(trash)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "projecteuler",
                    "title": "Project Euler",
                    "icon": "images/logo.svg"
                }
            ]
        },
        "views": {
            "projecteuler": [
                {
                    "id": "projecteuler.favorites",
                    "name": "Favorites",
                    "icon": "$(symbol-misc)"
                },
                {
                    "id": "projecteuler.problemView",
                    "name": "Problems",
                    "icon": "$(symbol-misc)"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "projecteuler.problemView",
                "contents": "No problem data found.\n[Refresh](command:projecteuler.refreshMetadata)"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "projecteuler.searchProblem"
                },
                {
                    "command": "projecteuler.pickProblem",
                    "when": "never"
                },
                {
                    "command": "projecteuler.showProblem",
                    "when": "never"
                },
                {
                    "command": "projecteuler.refreshMetadata",
                    "when": "never"
                },
                {
                    "command": "projecteuler.clearMetadata",
                    "when": "never"
                },
                {
                    "command": "projecteuler.newSubFolder",
                    "when": "never"
                },
                {
                    "command": "projecteuler.newFolder",
                    "when": "never"
                },
                {
                    "command": "projecteuler.addToFavorites",
                    "when": "never"
                },
                {
                    "command": "projecteuler.deleteFromFavorites",
                    "when": "never"
                }
            ],
            "view/title": [
                {
                    "command": "projecteuler.refreshMetadata",
                    "when": "view == projecteuler.problemView",
                    "group": "navigation"
                },
                {
                    "command": "projecteuler.pickProblem",
                    "when": "view == projecteuler.problemView",
                    "group": "navigation"
                },
                {
                    "command": "projecteuler.newFolder",
                    "when": "view == projecteuler.favorites",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "projecteuler.addToFavorites",
                    "when": "view == projecteuler.problemView && viewItem == euler_problem",
                    "group": "inline"
                },
                {
                    "command": "projecteuler.deleteFromFavorites",
                    "when": "view == projecteuler.favorites && viewItem == euler_problem",
                    "group": "inline"
                },
                {
                    "command": "projecteuler.newSubFolder",
                    "when": "view == projecteuler.favorites && viewItem == euler_folder",
                    "group": "inline"
                }
            ]
        },
        "icons": {
            "euler-problem": {
                "description": "Project Euler icon",
                "default": {
                    "fontPath": "./fileicons/seti.woff",
                    "fontCharacter": "\\E01D"
                }
            }
        },
        "colors": [
            {
                "id": "euler.iconColor",
                "description": "Color for Project Euler icon.",
                "defaults": {
                    "dark": "#519aba",
                    "light": "#498ba7",
                    "highContrast": "#010203",
                    "highContrastLight": "#feedc3"
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.7",
        "@types/node": "24.0.0",
        "@types/papaparse": "^5.5.2",
        "@types/vscode": "^1.109.0",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.4.0",
        "eslint": "^10.0.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.4.5",
        "webpack": "^5.105.2",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "cheerio": "^1.2.0",
        "papaparse": "^5.5.3"
    }
}
